{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@platform/shared-types": ["../../packages/shared-types/src/index.ts"],
      "@platform/shared-types/*": ["../../packages/shared-types/src/*"]
    }
  },
  "include": ["src"]
}
