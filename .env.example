# ============================================================
# Studio AI Builder — SaaS Deployment Environment Variables
# ============================================================
# Copy this file to .env and adjust values for your deployment.
# See docs/deployment.md for full deployment guide.

# --- Headless Mode ---
# Set to 1 to run without a GUI (required for server/VM deployment)
DYAD_HEADLESS=1

# --- HTTP Bridge Server ---
# Enables the HTTP bridge that exposes IPC channels over HTTP
# (Auto-enabled when DYAD_HEADLESS=1)
DYAD_ENABLE_WEB_BRIDGE=1

# Bridge server port
DYAD_WEB_BRIDGE_PORT=4310

# Bridge server bind address (use 127.0.0.1 if behind a reverse proxy)
DYAD_WEB_BRIDGE_HOST=0.0.0.0

# Authentication token for bridge API (generate with: openssl rand -hex 32)
DYAD_WEB_BRIDGE_TOKEN=changeme

# --- Rate Limiting ---
# Max requests per IP per minute (set to 0 to disable)
DYAD_RATE_LIMIT_PER_MINUTE=200

# --- Data Paths ---
# Override the default SQLite DB, settings, and backups directory
# Default: Electron userData directory
DYAD_DATA_DIR=/data/db

# Override the default user app projects directory
# Default: ~/dyad-apps
DYAD_APPS_DIR=/data/apps

# --- Web Studio (used by docker-compose / entrypoint) ---
# Public URL where the bridge is accessible from the browser.
# Used to inject window.__RUNTIME_CONFIG__ at startup.
BRIDGE_URL=https://studio.yourdomain.com

# --- Display (for xvfb in server environments) ---
DISPLAY=:99
